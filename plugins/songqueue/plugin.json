{
    "name": "Song Queue",
    "description": "Allows for songs to be requested by chat members. Adds functionality to the web and twitch bot interfaces.",
    "configs": {
        "Song-Queue": {
            "name": "Song Queue Configs",
            "description": "Collection of configurations for the Song Queue plugin.",
            "types": {
                "object": {
                    "fields": {
                        "B-Track": {
                            "name": "B-Track",
                            "description": "A separate track of music to play while the queue is empty.",
                            "types": {
                                "object": {
                                    "fields": {
                                        "url": {
                                            "name": "Playlist URL",
                                            "description": "A youtube.com/watch url with only the playlist ID set.",
                                            "types": {
                                                "string": true,
                                                "null": true
                                            }
                                        },
                                        "start": {
                                            "name": "Starting Index",
                                            "description": "An index in the playlist for the B-Track to start at.",
                                            "types": {
                                                "integer": {
                                                    ">": 0
                                                },
                                                "float": {
                                                    ">=": 1
                                                },
                                                "null": "exclude"
                                            },
                                            "optional": true
                                        },
                                        "random": {
                                            "name": "Shuffle",
                                            "description": "If set, shuffles the order the songs from the B-Track are selected to play in.",
                                            "types": {
                                                "boolean": true,
                                                "null": "exclude"
                                            },
                                            "default": false
                                        }
                                    }
                                },
                                "null": "exclude"
                            },
                            "optional": true
                        },
                        "Playlist": {
                            "name": "Save Playlist URL",
                            "description": "Playlist to save requested songs to.",
                            "types": {
                                "string": true,
                                "null": "exclude"
                            },
                            "optional": true
                        },
                        "Output-Device": {
                            "name": "Output Device",
                            "description": "Name of the output device to play audio to. Default is the desktop audio device. VB-Cable and Voicemeeter (or something equivalent) is recommended.",
                            "types": {
                                "string": true,
                                "null": "exclude"
                            },
                            "optional": true
                        },
                        "Song-Blacklist": {
                            "name": "Song Blacklist",
                            "description": "List of youtube links or youtube video IDs for songs that will not be allowed in the queue.",
                            "types": {
                                "list": {
                                    "types": {
                                        "string": true
                                    }
                                },
                                "null": "exclude"
                            },
                            "optional": true
                        }
                    }
                }
            }
        }
    }
}